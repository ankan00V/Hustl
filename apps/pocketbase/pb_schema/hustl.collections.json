      { "name": "matchRate", "type": "number", "min": 0, "max": 1 },
      { "name": "fastestMatchingSkill", "type": "text", "max": 80 }
    ],
    "indexes": ["CREATE UNIQUE INDEX idx_listing_analytics_daily_listing_date ON listing_analytics_daily (listing, date)"]
  }
]
