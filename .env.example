# ============================================
# HUSTL PLATFORM ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ============================================
# SHARED (Backend + Admin)
# ============================================
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hustl?schema=public
# DIRECT_URL is required for migrations when DATABASE_URL uses connection pooling
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/hustl?schema=public
REDIS_URL=redis://localhost:6379

# ============================================
# BACKEND API
# ============================================
PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:8081

# JWT Configuration
JWT_SECRET=replace-with-strong-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AUTHENTICATION
# ============================================
# Twilio OTP (Required for phone auth)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# STORAGE & MEDIA
# ============================================
# Cloudinary (Required for image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# PUSH NOTIFICATIONS
# ============================================
# Firebase Cloud Messaging (Required for mobile push)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Firebase_Private_Key\n-----END PRIVATE KEY-----\n"

# ============================================
# PAYMENTS & PAYOUTS
# ============================================
# Razorpay (Required for payments, escrow, payouts)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================
# FRAUD PREVENTION
# ============================================
# AWS Rekognition (Required for selfie verification)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_REKOGNITION_COLLECTION_ID=hustl-faces

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry (Optional but recommended for production)
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development

# ============================================
# ADMIN PANEL
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret-min-32-chars
ADMIN_EMAIL=admin@hustl.local
ADMIN_PASSWORD=change-this-in-production

# ============================================
# MOBILE APP (Expo)
# ============================================
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SOCKET_URL=http://localhost:4000
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to true to bypass OTP verification in development
DEV_BYPASS_OTP=false
# Set to true to use mock location in development
DEV_ALLOW_MOCK_LOCATION=false
